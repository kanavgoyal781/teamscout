# SQLite persistence
# Local relative paths resolve to backend/ (same DB for `make dev` and scripts).
# Fly prod (fly.toml): sqlite:////data/teamscout.db on volume.
DATABASE_URL=sqlite:///./teamscout.db
ENV=dev
LOG_LEVEL=INFO

# CORS — comma-separated origins (no wildcard in prod).
# ALLOWED_ORIGINS takes precedence when set; CORS_ORIGINS kept for compatibility.
# Prod: set to the Vercel frontend origin, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=

# App version / git SHA (baked by Docker build; optional locally)
APP_VERSION=
GIT_SHA=

# Frontend API base (browser calls backend — use host URL, not docker-internal DNS)
# Prod (Vercel): public Fly URL, e.g. https://teamscout-api.fly.dev
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Demo readiness script (make demo-check) — deployed API origin only
# DEMO_API_BASE=https://teamscout-api.fly.dev

# LLM (resume parsing + reranking)
# Prefer LLM_* names. OPENAI_API_KEY / OPENAI_BASE_URL are accepted as aliases.
LLM_API_KEY=
LLM_API_BASE=
# OPENAI_API_KEY=          # alias for LLM_API_KEY (and embeddings key if unset)
# OPENAI_BASE_URL=         # alias for LLM_API_BASE (and embeddings base if unset)
LLM_MODEL=gpt-4o-mini

# Embeddings (dense retrieval + eval_ranking.py)
# Use a real embeddings endpoint URL (not optional). Same OpenAI-compatible base
# as LLM is fine if the provider supports /embeddings.
EMBEDDINGS_API_KEY=
EMBEDDINGS_API=
EMBEDDINGS_MODEL=BAAI/bge-m3

# Jobs API — JSearch on RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JOBS_API_KEY=
JOBS_API_BASE=https://jsearch.p.rapidapi.com
JOBS_API_HOST=jsearch.p.rapidapi.com

# Ranking weights (optional overrides)
RANKING_WEIGHT_LLM=0.5
RANKING_WEIGHT_RRF=0.3
RANKING_WEIGHT_SKILLS=0.1
RANKING_WEIGHT_RECENCY=0.1
RRF_K=60
JOBS_FETCH_TARGET=150
JOBS_RECENCY_DAYS=14
RERANK_TOP_N=30
SEARCH_RESULTS_TOP_N=10
RECENCY_HALF_LIFE_DAYS=7
RESUME_RECOMMEND_TOP_N=3

# Sumble (team search + email reveal — https://docs.sumble.com/api/api)
SUMBLE_API_KEY=
SUMBLE_BASE_URL=https://api.sumble.com
SUMBLE_SEARCH_LIMIT=10
SUMBLE_JOB_MATCH_LIMIT=30

# Google Drive — public shared folder via API key (preferred)
GOOGLE_DRIVE_API_KEY=

# OAuth fallback (private folders)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# API hardening
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_FIND_TEAM=20/minute
RATE_LIMIT_REVEAL_EMAIL=30/minute
RATE_LIMIT_LLM=20/minute

# Outbound HTTP timeouts (seconds)
HTTP_TIMEOUT_DEFAULT=60
HTTP_TIMEOUT_EMBEDDINGS_BATCH=120
HTTP_TIMEOUT_DRIVE_DOWNLOAD=120

# Ops dashboard (/ops, /ops/json) — required; missing OPS_TOKEN denies all ops access.
# Prefer Authorization: Bearer <token> or X-Ops-Token header. Query ?token= is local-dev only.
OPS_TOKEN=

# Cost guardrails (fail closed with HTTP 429 when exceeded)
LLM_DAILY_COST_CEILING_USD=5
SUMBLE_DAILY_CREDIT_CEILING=1000

# Per-operation max_tokens budgets
LLM_MAX_TOKENS_PARSE_RESUME=4096
LLM_MAX_TOKENS_RERANK=6000
LLM_MAX_TOKENS_TEAM_EXTRACT=2048
LLM_MAX_TOKENS_JUSTIFY=6000
LLM_MAX_TOKENS_DEFAULT=4096

# Model prices (USD per 1M tokens)
LLM_PRICE_INPUT_PER_1M=0.15
LLM_PRICE_OUTPUT_PER_1M=0.60
EMBEDDINGS_PRICE_PER_1M=0.02

# Optional OTLP/HTTP JSON export (unset = SQLite traces only; must not break if unset)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional Litestream (Fly) — only when LITESTREAM_S3_BUCKET is set at container start.
# See litestream.yml + scripts/docker-entrypoint.sh and DEPLOYMENT.md.
# Credentials: LITESTREAM_ACCESS_KEY_ID/SECRET (mapped to AWS_*) or set AWS_* directly.
# For AWS S3: omit LITESTREAM_S3_ENDPOINT entirely (do not set it empty).
# LITESTREAM_S3_BUCKET=
# LITESTREAM_S3_REGION=us-east-1
# LITESTREAM_S3_ENDPOINT=   # R2/MinIO only
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=
